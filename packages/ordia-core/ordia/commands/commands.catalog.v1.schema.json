{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordia.dev/schemas/commands.catalog.v1.schema.json",
  "title": "Ordia command catalog v1",
  "type": "object",
  "required": ["sections"],
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "version": {},
        "profile": { "type": "string" },
        "locale": { "type": "string" },
        "generatedBy": { "type": "string" }
      },
      "additionalProperties": true
    },
    "quickFlows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "goal": { "type": "string" },
          "command": { "type": "string" },
          "commands": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "workflowIntents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "goal": { "type": "string" },
          "intent": { "type": "string" },
          "emitCommand": { "type": "string" },
          "relatedCommands": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "localUrls": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["commands"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "commands": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "description"],
              "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "examples": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "underlyingScript": { "type": "string" },
                "flags": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "description": { "type": "string" },
                      "default": { "type": "string" }
                    },
                    "additionalProperties": true
                  }
                },
                "requires": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "related": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "profile": { "type": "string" },
                "runtime": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "desktopCommands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "prefix": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
